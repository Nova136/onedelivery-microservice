{
    "scripts": {
        "build": "cd ../.. && nest build audit",
        "typeorm-migration": "cd .. && cd .. &&  ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "typeorm-migration-gen:audit": "npm run typeorm-migration -- -d apps/audit/typeorm-config.ts migration:generate apps/audit/src/database/migrations/Migrations",
        "typeorm-migration-run:audit": "npm run typeorm-migration -- -d apps/audit/typeorm-config.ts migration:run",
        "typeorm-migration-revert:audit": "npm run typeorm-migration -- -d apps/audit/typeorm-config.ts migration:revert",
        "test:unit": "jest --testMatch \"**/+(*.)+(spec).+(ts)\" ",
        "test:coverage": "jest --config jest.unit.config.js --coverage",
        "test:e2e:watch": "jest --watchAll",
        "test:e2e": "jest --testMatch \"**/+(*.)+(e2e-spec).+(ts)\"",
        "test:e2e:coverage": "jest --coverage",
        "seed:run": "ts-node -r tsconfig-paths/register seed"
    }
}
