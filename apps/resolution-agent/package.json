{
    "scripts": {
        "build": "cd ../.. && nest build resolution-agent",
        "typeorm-migration": "cd .. && cd .. &&  ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "typeorm-migration-gen:resolution-agent": "npm run typeorm-migration -- -d apps/resolution-agent/typeorm-config.ts migration:generate apps/resolution-agent/src/database/migrations/Migrations",
        "typeorm-migration-run:resolution-agent": "npm run typeorm-migration -- -d apps/resolution-agent/typeorm-config.ts migration:run",
        "typeorm-migration-revert:resolution-agent": "npm run typeorm-migration -- -d apps/resolution-agent/typeorm-config.ts migration:revert",
        "test:unit": "jest --testMatch \"**/+(*.)+(spec).+(ts)\" ",
        "test:e2e:watch": "jest --watchAll",
        "test:e2e": "jest --testMatch \"**/+(*.)+(e2e-spec).+(ts)\"",
        "test:e2e:coverage": "jest --coverage",
        "seed:run": "ts-node -r tsconfig-paths/register seed",
        "test:coverage": "jest --config jest.unit.config.js --coverage"
    }
}
