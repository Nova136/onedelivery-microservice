{
  "scripts": {
    "typeorm-migration": "cd .. && cd .. &&  ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm-migration-gen:orchestrator-agent": "npm run typeorm-migration -- -d apps/orchestrator-agentlog/typeorm-config.ts migration:generate apps/orchestrator-agent/src/database/migrations/Migrations",
    "typeorm-migration-run:orchestrator-agent": "npm run typeorm-migration -- -d apps/orchestrator-agent/typeorm-config.ts migration:run",
    "typeorm-migration-revert:orchestrator-agent": "npm run typeorm-migration -- -d apps/orchestrator-agent/typeorm-config.ts migration:revert",
    "test:unit": "jest --testMatch \"**/+(*.)+(spec).+(ts)\" ",
    "test:e2e:watch": "jest --watchAll",
    "test:e2e": "jest --testMatch \"**/+(*.)+(e2e-spec).+(ts)\"",
    "test:e2e:coverage": "jest --coverage",
    "seed:run": "ts-node -r tsconfig-paths/register seed"
  }
}