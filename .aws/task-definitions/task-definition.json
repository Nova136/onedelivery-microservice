{
  "family": "onedelivery-${MICROSERVICE_NAME}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::542829982577:role/onedelivery-ecs-exec",
  "taskRoleArn": "arn:aws:iam::542829982577:role/onedelivery-ecs-task",
  "containerDefinitions": [
    {
      "name": "${MICROSERVICE_NAME}",
      "image": "542829982577.dkr.ecr.ap-southeast-1.amazonaws.com/onedelivery-${MICROSERVICE_NAME}:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "DATABASE_URL",
          "value": "postgresql://postgres:REDACTED_DB_PASSWORD@onedelivery-aurora.cluster-chqkmym8y08l.ap-southeast-1.rds.amazonaws.com:5432/onedelivery"
        },
        {
          "name": "JWT_SECRET",
          "value": "REDACTED_JWT_SECRET"
        },
        {
          "name": "POSTGRES_USER",
          "value": "postgres"
        },
        {
          "name": "POSTGRES_PASSWORD",
          "value": "REDACTED_DB_PASSWORD"
        },
        {
          "name": "POSTGRES_DB",
          "value": "onedelivery"
        },
        {
          "name": "POSTGRES_PORT",
          "value": "5432"
        },
        {
          "name": "RABBITMQ_USER",
          "value": "rabbit"
        },
        {
          "name": "RABBITMQ_PASSWORD",
          "value": "rabbit"
        },
        {
          "name": "RABBITMQ_AMQP_PORT",
          "value": "5672"
        },
        {
          "name": "RABBITMQ_AMQPS_PORT",
          "value": "5671"
        },
        {
          "name": "RABBITMQ_MGMT_PORT",
          "value": "15672"
        },
        {
          "name": "RABBITMQ_URL",
          "value": "amqps://grdulrnl:REDACTED_CLOUDAMQP_PASSWORD@armadillo.rmq.cloudamqp.com:5671/grdulrnl"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/onedelivery-${MICROSERVICE_NAME}",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "${MICROSERVICE_NAME}"
        }
      }
    }
  ]
}