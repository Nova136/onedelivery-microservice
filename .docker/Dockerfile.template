# ---- build stage ----
FROM node:24-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG SERVICE_NAME
RUN npx nest build ${SERVICE_NAME}

# ---- runtime stage ----
FROM node:24-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/dist ./dist

ARG SERVICE_NAME
ARG EXPOSE_PORT

ENV SERVICE_NAME=${SERVICE_NAME}
EXPOSE ${EXPOSE_PORT}
CMD ["sh", "-c", "node ./dist/apps/$SERVICE_NAME/main.js"]
