# Copy to .env and adjust. Used by docker-compose and optionally by apps.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=onedelivery
POSTGRES_PORT=5432
# Connection string (each microservice uses same DB, its own schema via TypeORM):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onedelivery

# --- RabbitMQ (event bus) ---
# CloudAMQP: use amqps and port 5671 for TLS; local: amqp and 5672
RABBITMQ_USER=rabbit
RABBITMQ_PASSWORD=rabbit
RABBITMQ_AMQP_PORT=5672
RABBITMQ_AMQPS_PORT=5671
RABBITMQ_MGMT_PORT=15672
# Connection URL (for apps). TLS: amqps on port 5671; non-TLS: amqp on 5672
RABBITMQ_URL=amqp://rabbit:rabbit@localhost:5672

# --- Kong (API gateway, local dev) ---
# Frontend and API clients point to http://localhost:8000 ; Kong routes /order, /logistics, etc. to microservices.
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# --- LocalStack (S3 + SNS) ---
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0
# For AWS SDK in apps (local dev):
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_REGION=us-east-1
# S3_BUCKET=onedelivery-bucket
# SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:onedelivery-events

JWT_SECRET=REDACTED_JWT_SECRET

AUDIT_PORT=3001
LOGISTICS_PORT=3002
ORDER_PORT=3003
PAYMENT_PORT=3004
USER_PORT=3005
